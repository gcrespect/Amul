name: Keep Alive

on:
  schedule:
    - cron: '0 */6 * * *'  # Every 6 hours

jobs:
  keepalive:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Keep repo active
        run: |
          git config user.email "action@github.com"
          git config user.name "GitHub Action"
          git commit --allow-empty -m "Keep alive"
          git push
